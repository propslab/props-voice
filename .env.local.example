# Supabase（Supabase ダッシュボード → Project Settings → API から取得）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API（https://console.anthropic.com/ で発行）
ANTHROPIC_API_KEY=

# 公開URL（本番: https://voice.props-lab.com、開発: http://localhost:3000）
NEXT_PUBLIC_APP_URL=http://localhost:3000


# 月の整文上限（任意）
# - 未設定または "3" 等の正の数 → その人数で制限
# - "0" または負の数 → 無制限（ローンチ前テスト用）
# 本番（ローンチ後）はこの変数を設定しないか "3" を設定
POLISH_MONTHLY_LIMIT=
